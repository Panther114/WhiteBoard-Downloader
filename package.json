{
  "name": "whiteboard-downloader",
  "version": "2.0.0",
  "description": "Modern, async-first automation tool to download course materials from SHSID Blackboard China",
  "main": "dist/index.js",
  "bin": {
    "whiteboard-dl": "./dist/cli.js"
  },
  "scripts": {
    "bootstrap": "node scripts/bootstrap.js",
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "setup": "node dist/cli.js setup",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "docker:build": "docker build -t whiteboard-downloader .",
    "docker:run": "docker run -it --rm -v $(pwd)/downloads:/app/downloads whiteboard-downloader"
  },
  "keywords": [
    "blackboard",
    "downloader",
    "automation",
    "education",
    "web-scraping"
  ],
  "author": "Gavania",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.2.2",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "inquirer": "^8.2.5",
    "mime-types": "^2.1.35",
    "ora": "^5.4.1",
    "p-limit": "^3.1.0",
    "p-retry": "^4.6.2",
    "playwright": "^1.40.0",
    "sanitize-filename": "^1.6.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.10",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0 <24.0.0",
    "npm": ">=8.0.0"
  }
}
