# Blackboard Credentials
BB_USERNAME=your_g_number
BB_PASSWORD=your_password

# Blackboard URL
BB_BASE_URL=https://shs.blackboardchina.cn
BB_LOGIN_URL=https://shs.blackboardchina.cn/webapps/login/

# Download Settings
DOWNLOAD_DIR=./downloads
MAX_CONCURRENT_DOWNLOADS=5
DOWNLOAD_TIMEOUT=60000

# Browser Settings (Playwright)
BROWSER_TYPE=chromium
HEADLESS=true
BROWSER_TIMEOUT=30000

# Database
DATABASE_PATH=./whiteboard.db

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/whiteboard.log

# Course Filter (optional - regex pattern)
# COURSE_FILTER=^2025I.*

# Retry Settings
MAX_RETRIES=3
RETRY_DELAY=2000
